# KAOS — variables de entorno (.env)
# Copia este archivo a `.env` y completa los valores. Todo es opcional:
# sin configuración, `kaos up` corre el demo offline (conversación estática
# + salida por consola).

# ─────────────────────────────────────────────────────────────
# LLM Provider
# ─────────────────────────────────────────────────────────────
# echo   -> EchoLLMProvider (sin red, para demo/tests)
# openai -> endpoint OpenAI-compatible (usa KAOS_LLM_API_KEY / KAOS_LLM_BASE_URL)
# github -> GitHub Models (usa KAOS_GITHUB_TOKEN o GITHUB_TOKEN)
# anthropic -> Claude vía endpoint OpenAI-compatible de Anthropic (usa KAOS_ANTHROPIC_API_KEY)
KAOS_LLM_PROVIDER=echo
KAOS_LLM_MODEL=gpt-4o-mini

# Timeout (segundos) por llamada al LLM. Súbelo para modelos de razonamiento
# lentos (p. ej. gpt-5 vía GitHub Models puede tardar > 120s). Default: 120.
KAOS_LLM_TIMEOUT=120

# Para KAOS_LLM_PROVIDER=openai
KAOS_LLM_API_KEY=
# Opcional: sobreescribe el endpoint (OpenAI, Azure, Ollama, etc.)
KAOS_LLM_BASE_URL=

# Para KAOS_LLM_PROVIDER=github (GitHub Models). También se acepta GITHUB_TOKEN.
KAOS_GITHUB_TOKEN=

# Para KAOS_LLM_PROVIDER=anthropic (Claude). También se acepta ANTHROPIC_API_KEY.
# Modelo por defecto: claude-3-5-haiku-latest (setea KAOS_LLM_MODEL para otro).
KAOS_ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# Discord
# ─────────────────────────────────────────────────────────────
# Token del bot de Discord. Si se define, KAOS usa el gateway real y publica
# el resumen en un thread de Discord; si se deja vacío, corre el demo offline.
KAOS_DISCORD_TOKEN=
# Guild (servidor) a observar; se usa como workspace (discord:<guild_id>).
KAOS_DISCORD_GUILD_ID=
# IDs de canales a observar, separados por coma. Vacío = todos.
KAOS_DISCORD_CHANNEL_IDS=
# Nombre del thread donde se publican los resúmenes (modo bot token).
KAOS_RESUME_THREAD_NAME=📋 Resume

# Publicación vía webhook (solo escritura, sin bot token). Si se define, KAOS
# publica los resúmenes con este webhook. Regenera el webhook si se expone.
KAOS_DISCORD_WEBHOOK_URL=
# ID del thread destino para el webhook (p. ej. el hilo "PMO" de un foro).
KAOS_DISCORD_RESUME_THREAD_ID=

# Backfill: si se define (con KAOS_DISCORD_TOKEN), KAOS lee el historial de este
# canal/hilo por REST y lo resume una vez. Ideal para un hilo de foro.
KAOS_DISCORD_BACKFILL_CHANNEL_ID=
# Máximo de mensajes históricos a leer (paginado).
KAOS_DISCORD_MESSAGE_LIMIT=100

# ─────────────────────────────────────────────────────────────
# Persistencia
# ─────────────────────────────────────────────────────────────
# Si se define, KAOS persiste eventos y artifacts en PostgreSQL (requiere el
# extra `.[postgres]`). Vacío = almacenamiento en memoria.
# Con los contenedores de docker/docker-compose.yml:
KAOS_DATABASE_URL=postgresql://kaos:kaos@localhost:5432/kaos

# ─────────────────────────────────────────────────────────────
# Scheduler (Beta)
# ─────────────────────────────────────────────────────────────
# Segundos entre corridas de `kaos schedule` (envuelve `kaos run`, idempotente:
# solo publica si algún hilo cambió). Default: 900 (15 min).
KAOS_SCHEDULER_INTERVAL=900

# ─────────────────────────────────────────────────────────────
# Infraestructura (futuro — aún no usada por el Runtime en alpha)
# ─────────────────────────────────────────────────────────────
# KAOS_REDIS_URL=redis://localhost:6379/0
# KAOS_MINIO_ENDPOINT=localhost:9000
# KAOS_MINIO_ACCESS_KEY=kaos
# KAOS_MINIO_SECRET_KEY=kaos12345
